<script>
  document.addEventListener('DOMContentLoaded', () => {
  // Get all dropdown details elements
  const dropdowns = document.querySelectorAll('.menu-horizontal details');
  
  // Function to close all dropdowns
  const closeAllDropdowns = () => {
    dropdowns.forEach(dropdown => {
      dropdown.removeAttribute('open');
    });
  };
  
  // Function to close all dropdowns except the one clicked
  const closeOtherDropdowns = (currentDropdown) => {
    dropdowns.forEach(dropdown => {
      if (dropdown !== currentDropdown) {
        dropdown.removeAttribute('open');
      }
    });
  };
  
  // Add click event to each dropdown
  dropdowns.forEach(dropdown => {
    dropdown.addEventListener('click', (e) => {
      // Prevent the click from bubbling up to document
      e.stopPropagation();
      
      // Close other dropdowns when one is clicked
      closeOtherDropdowns(dropdown);
    });
  });
  
  // Add click event to document to close all dropdowns when clicking outside
  document.addEventListener('click', () => {
    closeAllDropdowns();
  });
  
  // Prevent dropdown from closing when clicking inside the dropdown content
  const dropdownContents = document.querySelectorAll('.menu-horizontal details ul');
    dropdownContents.forEach(content => {
      content.addEventListener('click', (e) => {
        // Prevent the click from closing the dropdown
        e.stopPropagation();
      });
    });
  });
</script>
