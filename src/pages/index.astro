---
import { Image } from 'astro:assets'
import Layout from '../layouts/Layout.astro';
import heroImage from '../assets/images/home/hero.png';
---

<Layout title="Association Sanctopia">
  <div class="relative">
    <Image src={heroImage} alt="Sanctopia hero" class="max-w-none min-h-screen w-full object-cover object-top" />
    <div class="flex flex-col absolute inset-0 h-screen">
      <div class="flex flex-col justify-center items-center h-1/3 lg:h-1/2">
        <p class="suptitle">L'association</p>
        <h1 class="title">Sanctopia</h1>
        <p class="subtitle">Tissons une utopie animale</p>
      </div>
      <div class="flex items-end justify-center h-1/3">
        <a class="btn btn-xl btn-neutral" href="/">Faire un don</a>
      </div>
    </div>
    <section>
    </section>
  </div>
</Layout>
