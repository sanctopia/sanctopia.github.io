---
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import ParallaxHero from '../components/ParallaxHero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import heroImage from '../assets/images/home/hero.png';
import layer0 from '../assets/images/home/hero_layers/layer_0.png';
import layer1 from '../assets/images/home/hero_layers/layer_1.png';
import layer2 from '../assets/images/home/hero_layers/layer_2.png';
import layer3 from '../assets/images/home/hero_layers/layer_3.png';
import layer4 from '../assets/images/home/hero_layers/layer_4.png';
import dystopia from '../assets/images/home/dystopia.png';

const projects = (await getCollection('projects')).sort((a, b) => a.data.position - b.data.position);
---

<Layout title="Association Sanctopia" description="Sanctopia est la vision d’un monde anti-spéciste où tous les animaux, sans distinction d’espèce, sont traités avec le même respect, la même bienveillance et le même soin que dans un sanctuaire.">
  <div class="relative">
    <ParallaxHero images={[heroImage, layer0, layer1, layer2, layer3, layer4]} />
    <div class="flex flex-col absolute inset-0 h-dvh">
      <div class="flex flex-col justify-center items-center h-1/3 lg:h-1/2 overflow-hidden">
        <p class="suptitle motion-preset-slide-down">L'association</p>
        <h1 class="title motion-preset-focus motion-preset-shrink">Sanctopia</h1>
        <p class="subtitle motion-preset-slide-up">Tissons une utopie animale</p>
      </div>
      <div class="flex items-end justify-center h-1/2 md:h-1/3 lg:h-1/4">
        <a class="btn btn-xl btn-neutral motion-preset-slide-up" href="/">Faire un don</a>
      </div>
    </div>
    <section class="overflow-hidden bg-base-200">
      <div class="bg-dark-green pt-6 lg:pt-36 lg:pb-24">
        <div class="flex flex-col lg:gap-2 items-center">
          <h2 class="h2 intersect:motion-preset-slide-right motion-duration-500">Nos projets</h2>
          <p class="text-neutral text-center text-sm lg:text-lg intersect:motion-preset-slide-left motion-duration-500">Chaque projet a pour but d’aider la cause animale</p>
        </div>
        <div class="flex flex-row">
          <ul class="carousel carousel-center md:justify-center w-full gap-4 py-12 px-4">
            {projects.map(project => (
              <li class="carousel-item w-full max-w-96">
                <ProjectCard {...project.data} />
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
    <div class="wave-container relative">
    </div>
    <section class="bg-base-200 min-h-dvh flex items-center overflow-hidden lg:overflow-visible">
      <div class="w-full max-w-5xl mx-auto px-4 flex flex-col lg:flex-row gap-12 py-24 md:py-36">
        <div class="flex flex-col lg:flex-row gap-12 lg:gap-24">
          <div class="lg:w-1/2 text-center lg:text-right intersect:motion-preset-slide-right motion-duration-500">
            <div class="sticky top-0">
              <h2 class="font-serif text-5xl lg:text-7xl font-black uppercase text-gold">Nos valeurs</h2>
              <p class="text-lg">Elles sont engravées dans notre nom</p>
              <a href="/nos-valeurs" class="mt-6 hidden lg:block font-bold underline text-base text-primary text-right">En savoir plus →</a>
            </div>
          </div>
          <div class="card rounded-xl card-xl bg-base-100 shadow-lg intersect:motion-preset-slide-left motion-duration-500">
            <div class="card-body gap-6">
              <p class="text-2xl card-title"><strong>Sanctopia</strong><span class="text-lg opacity-50">•</span><span class="italic text-sm font-normal">sãk.tɔ.pja n.f.</span></p>
              <div class="italic text-base text-primary">
                Étymologie :
                Fusion des mots <span class="underline">sanctuaire</span> et <span class="underline">utopie</span>, Sanctopia évoque un refuge parfait, un havre de paix pour tous les êtres sensibles.
              </div>
              <ol class="flex flex-col gap-2 text-lg list-decimal">
                <li>
                  <strong>Vision d’un monde anti-spéciste et pro-sentience</strong> où tous les animaux, sans distinction d’espèce, sont traités avec le même respect, la même bienveillance et le même soin que dans un sanctuaire.
                </li>
                <li>
                  <strong>Utopie éthique</strong> fondée sur la reconnaissance de la sensibilité animale et le rejet de toute forme d’exploitation, où chaque action humaine est guidée par l’intérêt et le bien-être des animaux.
                </li>
              </ol>
            </div>
          </div>
          <a href="/nos-valeurs" class="lg:hidden font-bold underline text-base text-primary text-right">En savoir plus →</a>
        </div>
      </div>
    </section>
    <section class="bg-base-100 relative">
      <div class="h-dvh sticky top-0">
        <Image src={dystopia} alt="Dystopie animale" class="absolute inset-0 w-full h-full object-cover object-top z-0" />
        <div class="w-full max-w-5xl mx-auto px-4 flex flex-col gap-12 py-36 relative h-full items-center justify-center">
          <div class="flex flex-col items-center justify-center gap-24">
            <div class="text-center mt-12 sm:mt-0">
              <h2 class="font-serif text-4xl md:text-5xl lg:text-7xl font-black uppercase text-gold">Notre mission</h2>
              <p class="text-lg text-white">Éveiller les conscience de la dystopie animale pour en mettre fin</p>
            </div>
          </div>
        </div>
      </div>
      <div class="bg-black h-dvh relative z-20">
      </div>
    </section>
  </div>
</Layout>
